# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (never commit these)
.venv/
venv/
env/
ENV/

# Editor / tool local settings
.claude/
.idea/
.vscode/

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test / type-checker caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Stray / temporary files
*.tmp
file.tmp

# DiffusionNet eigenbasis cache (large .npz files, regenerated per machine)
op_cache/

# NOTE: checkpoints/ is deliberately TRACKED in git. The .ckpt files carry the
# full training state (weights + optimizer + epoch), so committing and pushing
# them lets any other machine `git pull` and continue training with --resume.

# OS cruft
.DS_Store
Thumbs.db
